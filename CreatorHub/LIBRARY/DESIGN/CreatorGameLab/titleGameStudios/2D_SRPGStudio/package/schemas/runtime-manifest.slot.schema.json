{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "creator-game-lab.runtime-manifest-slot.schema.v0.1",
  "title": "Runtime Manifest Slot",
  "type": "object",
  "required": ["slotId", "schemaVersion", "status", "runtimeTargets"],
  "properties": {
    "slotId": { "const": "slot_runtime_manifest" },
    "schemaVersion": { "const": "creator-game-lab.runtime-manifest-slot.v0.1" },
    "status": { "type": "string" },
    "sourceRuntimeManifest": { "type": "string" },
    "runtimeTargets": { "type": "array", "items": { "type": "object" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}

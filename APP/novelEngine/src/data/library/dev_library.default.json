  "meta": {
    "id": "dev_library_default",
    "version": "0.4.5",
    "purpose": "CodexとDevStudioが初期状態で参照する制作DB。キャラクター、背景、UI、音、仮素材方針を一枚で管理する。",
    "format": "one_json_dev_library",

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Enable the original Note app Firestore collections such as memos/blogs/products.
# Keep this false when using the kanban_June Firebase project unless its rules allow those collections.
VITE_ENABLE_FIREBASE=false

# Enable sending selected notes to kanban_June's Codex相談Inbox.
VITE_ENABLE_KANBAN_MEMO_SYNC=true
VITE_KANBAN_MEMO_COLLECTION=memoArchive
